{
  "name": "minigraph-playground-webapp",
  "version": "1.0.0",
  "description": "A lightweight React-based Minigraph playground for testing and debugging",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf ../src/main/resources/public/*",
    "build:deploy": "npm run build && npm run deploy",
    "deploy": "cp -r dist/* ../src/main/resources/public/"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^6.0.5"
  }
}
